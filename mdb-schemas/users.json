{
	"collection": "users",
	"validator": {
		"$jsonSchema": {
			"bsonType": "object",
			"required": [
				"email",
				"username",
				"password_hash",
				"role",
				"created_at",
				"updated_at"
			],
			"additionalProperties": false,
			"properties": {
				"_id": { "bsonType": "objectId" },
				"email": {
					"bsonType": "string",
					"description": "Unique user email address"
				},
				"username": {
					"bsonType": "string",
					"description": "Unique display name"
				},
				"password_hash": {
					"bsonType": "string",
					"description": "bcrypt hash, cost 12"
				},
				"role": { "bsonType": "string", "enum": ["user", "admin"] },
				"created_at": { "bsonType": "date" },
				"updated_at": { "bsonType": "date" }
			}
		}
	},
	"indexes": [
		{
			"key": { "email": 1 },
			"name": "email_unique",
			"unique": true
		},
		{
			"key": { "username": 1 },
			"name": "username_unique",
			"unique": true
		}
	]
}
