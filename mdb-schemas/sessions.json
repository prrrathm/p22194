{
  "collection": "sessions",
  "validator": {
    "$jsonSchema": {
      "bsonType": "object",
      "required": ["user_id", "token_hash", "expires_at", "created_at"],
      "additionalProperties": false,
      "properties": {
        "_id":        { "bsonType": "objectId" },
        "user_id":    { "bsonType": "objectId", "description": "Reference to users._id" },
        "token_hash": { "bsonType": "string",   "description": "SHA-256 hex digest of raw refresh UUID" },
        "expires_at": { "bsonType": "date",     "description": "Session expiry; TTL index auto-removes expired docs" },
        "created_at": { "bsonType": "date" }
      }
    }
  },
  "indexes": [
    {
      "key": { "token_hash": 1 },
      "name": "token_hash_unique",
      "unique": true
    },
    {
      "key": { "expires_at": 1 },
      "name": "expires_at_ttl",
      "expireAfterSeconds": 0
    },
    {
      "key": { "user_id": 1 },
      "name": "user_id"
    }
  ]
}
